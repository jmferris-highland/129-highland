    {
        "id": "28d9d10ad8d281c3",
        "type": "function",
        "z": "utility-logging",
        "g": "4c0f3961b5bcf044",
        "name": "Prepare Entry",
        "func": "const now = new Date();\n\n// Local formatStatus — intentionally not using utils to avoid initializer dependency\nconst formatStatus = (text) => {\n    const ts = new Date().toLocaleString('en-US', {\n        month: 'short', day: 'numeric',\n        hour: 'numeric', minute: '2-digit', hour12: true\n    });\n    return `${text} at: ${ts}`;\n};\n\n// Build daily filename\nconst dateStr = now.toISOString().slice(0, 10); // YYYY-MM-DD\nmsg.filename = `/var/log/highland/highland-${dateStr}.jsonl`;\n\n// Validate and normalize the log entry\nlet entry = msg.payload;\n\nif (typeof entry !== 'object' || entry === null) {\n    // Wrap malformed input rather than drop it\n    entry = {\n        timestamp: now.toISOString(),\n        system:    'node_red',\n        source:    'logging_utility',\n        level:     'WARN',\n        message:   'Received malformed log entry',\n        context:   { raw: String(msg.payload) }\n    };\n} else {\n    // Ensure timestamp is present\n    if (!entry.timestamp) {\n        entry.timestamp = now.toISOString();\n    }\n}\n\n// Preserve structured entry for downstream Switch node\nmsg.logEntry = entry;\n\n// Serialize for file append\nmsg.payload = JSON.stringify(entry);\n\n// Node status — color coded by level\nconst levelColors = {\n    VERBOSE:  { fill: 'grey',   shape: 'dot'  },\n    DEBUG:    { fill: 'grey',   shape: 'dot'  },\n    INFO:     { fill: 'green',  shape: 'dot'  },\n    WARN:     { fill: 'yellow', shape: 'dot'  },\n    ERROR:    { fill: 'red',    shape: 'dot'  },\n    CRITICAL: { fill: 'red',    shape: 'ring' }\n};\n\nconst level  = entry.level || 'INFO';\nconst color  = levelColors[level] || { fill: 'grey', shape: 'dot' };\n\nnode.status({ fill: color.fill, shape: color.shape, text: formatStatus(level) });\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 80,
        "wires": [
            [
                "51eb59b6bc35d7ac"
            ]
        ]
    },
