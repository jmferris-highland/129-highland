    {
        "id": "70c3c10a5b80abee",
        "type": "function",
        "z": "utility-device-registry",
        "g": "dc5aa602fab26888",
        "name": "Assemble Results",
        "func": "// Build areas map\nconst areasMap = {};\nfor (const area of msg.registry.areas) {\n    areasMap[area.area_id] = {\n        name: area.name,\n        floor_id: area.floor_id\n    };\n}\n\n// Build entity index by device_id for fast lookup\nconst entitiesByDevice = {};\nfor (const entity of msg.registry.entities) {\n    if (!entitiesByDevice[entity.device_id]) {\n        entitiesByDevice[entity.device_id] = [];\n    }\n    entitiesByDevice[entity.device_id].push(entity);\n}\n\n// Filter and build devices\nconst devices = {};\nfor (const device of msg.registry.devices) {\n    // Skip infrastructure: service entries and devices with no parent\n    if (device.entry_type !== null) continue;\n    if (!device.via_device_id) continue;\n\n    // Determine protocol from identifiers\n    const identifierPlatforms = device.identifiers.map(i => i[0]);\n    let protocol = null;\n    if (identifierPlatforms.some(p => p === 'mqtt')) protocol = 'zigbee';\n    else if (identifierPlatforms.some(p => p === 'zwave_js')) protocol = 'zwave';\n    else continue; // skip non-highland devices\n\n    // Find battery entity\n    const deviceEntities = entitiesByDevice[device.id] || [];\n    const batteryEntity = deviceEntities.find(\n        e => e.original_name === 'Battery' && e.disabled_by === null\n    );\n\n    // Resolve area\n    const area = device.area_id ? areasMap[device.area_id] : null;\n\n    const key = device.name;\n    const friendlyName = device.name_by_user || device.name;\n\n    devices[key] = {\n        ha_device_id: device.id,\n        friendly_name: friendlyName,\n        manufacturer: device.manufacturer,\n        model: device.model,\n        model_id: device.model_id,\n        area_id: device.area_id,\n        floor_id: area?.floor_id || null,\n        protocol,\n        battery_pct_entity: batteryEntity?.entity_id || null\n    };\n}\n\nmsg.payload = {\n    devices,\n    areas: areasMap,\n    meta: {\n        last_refreshed: new Date().toISOString(),\n        device_count: Object.keys(devices).length,\n        source: 'ha_registry'\n    }\n};\n\nconst formatStatus = global.get('utils.formatStatus', 'initializers');\nnode.status({ fill: 'green', shape: 'dot', \n    text: formatStatus(`Built — ${Object.keys(devices).length} devices`) });\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
