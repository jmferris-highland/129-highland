        "g": "47ba118428e5ba52",
        "name": "Format Log Message",
        "func": "const formatStatus = global.get('utils.formatStatus', 'initializers') || (t => t);\n\nconst parts = msg.topic.split('/');\nconst product = parts[4];\n\nconst ts = parseInt(msg.payload);\nconst formatted = isNaN(ts) ? msg.payload : new Date(ts * 1000).toISOString();\n\nnode.status({ fill: 'green', shape: 'dot', text: formatStatus(`${product.toUpperCase()}`)});\n\nmsg.payload = {\n    timestamp: new Date().toISOString(),\n    system: 'hub_daemon',\n    source: `weather.radar.${product}`,\n    level: 'INFO',\n    message: `Radar loop last updated: ${product}`,\n    context: { product, last_updated: formatted }\n};\n\nreturn msg;",
