        "func": "msg.payload = {\n    timestamp: new Date().toISOString(),\n    system: 'node_red',\n    source: 'connections',\n    level: msg.connection.state === 'up' ? 'INFO' : 'WARN',\n    message: `${msg.connection.name} connection ${msg.connection.state === 'up' ? 'established' : 'lost'}`,\n    context: {}\n};\n\nreturn msg;",
