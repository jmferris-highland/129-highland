    {
        "id": "ba22",
        "type": "function",
        "z": "utility-backup",
        "g": "ba-g03",
        "name": "Evaluate Result",
        "func": "const formatStatus = global.get('utils.formatStatus', 'initializers');\n\nconst lastBackupStr = msg.payload;  // e.g. \"2026-03-27T09:37:28+00:00\"\nconst lastBackup = new Date(lastBackupStr);\nconst now = new Date();\n// @ts-ignore\nconst elapsedMs = now - lastBackup;\n// 2 decimal places: Math.round(ms / 36000) / 100 === hours\nconst elapsedHours = Math.round(elapsedMs / 36000) / 100;\nconst windowMs = 26 * 60 * 60 * 1000;\nconst ts = now.toISOString();\n\nif (elapsedMs > windowMs) {\n    msg.payload = {\n        host: \"ha\",\n        status: \"failed\",\n        elapsed_hours: elapsedHours,\n        timestamp: ts\n    };\n    msg.topic = \"highland/event/backup/failed\";\n\n    node.status({ fill: 'red', shape: 'dot', text: formatStatus(`Stale — ${elapsedHours}h ago`) });    \n\n    return [null, msg];\n} else {\n    msg.payload = {\n        host: \"ha\",\n        status: \"completed\",\n        elapsed_hours: elapsedHours,\n        timestamp: ts\n    };\n    msg.topic = \"highland/event/backup/completed\";\n\n    node.status({ fill: 'green', shape: 'dot', text: formatStatus(`OK — ${elapsedHours}h ago`) });\n    \n    return [msg, null];\n}",
