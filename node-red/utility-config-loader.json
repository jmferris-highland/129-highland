        "func": "// Inline — intentionally not using utils.formatStatus, initializers store is unavailable\nconst ts = new Date().toLocaleString('en-US', {\n    month: 'short', day: 'numeric',\n    hour: 'numeric', minute: '2-digit', hour12: true\n});\nnode.status({ fill: 'red', shape: 'ring', text: `Degraded at: ${ts}` });\n\nmsg.topic = 'highland/event/log';\nmsg.payload = {\n    timestamp: new Date().toISOString(),\n    system:    'node_red',\n    source:    'config_loader',\n    level:     'CRITICAL',\n    message:   'Initializer latch timed out — config will not be loaded',\n    context:   {}\n};\nreturn msg;",
