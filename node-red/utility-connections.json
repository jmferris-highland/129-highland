        "g": "a1766f6d6d10467b",
        "name": "Evaluate State",
        "func": "const formatStatus = global.get('utils.formatStatus', 'initializers');\nconst TIMER_CADENCE = flow.get('timer_cadence') || 5000;\n\nconst NAME = 'MQTT';\nconst KEY = 'mqtt';\n\nconst CURRENT_STATE = (msg.status.fill === 'red' || msg.status.fill === 'yellow') ? 'down' : 'up';\nconst LAST_STATE = global.get(`connections.${KEY}`) || 'unknown';\n\n// Always update the global flag and node status immediately\nglobal.set(`connections.${KEY}`, CURRENT_STATE);\nnode.status({\n    fill: CURRENT_STATE === 'up' ? 'green' : 'red',\n    shape: CURRENT_STATE === 'up' ? 'dot' : 'ring',\n    text: formatStatus(CURRENT_STATE.toUpperCase())\n});\n\nif (CURRENT_STATE === LAST_STATE) return null;\n\nconst SETTLED = flow.get('settled', 'volatile') || false;\n\nif (!SETTLED) {\n    // Startup window — debounce down transitions\n    if (CURRENT_STATE === 'down') {\n        const CONNECTION_SNAPSHOT = { key: KEY, name: NAME, state: 'down' };\n        const TIMER_ID = setTimeout(() => {\n            if (global.get(`connections.${KEY}`) === 'down') {\n                flow.set(`${KEY}_timer`, null, 'volatile');\n                node.send({ connection: CONNECTION_SNAPSHOT });\n            }\n        }, TIMER_CADENCE);\n        flow.set(`${KEY}_timer`, TIMER_ID, 'volatile');\n        return null;\n    }\n    // Coming up during startup window — cancel any pending timer, no log\n    const TIMER_ID = flow.get(`${KEY}_timer`, 'volatile');\n    if (TIMER_ID) {\n        clearTimeout(TIMER_ID);\n        flow.set(`${KEY}_timer`, null, 'volatile');\n    }\n    return null;\n}\n\n// Settled — real-time, log immediately\nmsg.connection = { key: KEY, name: NAME, state: CURRENT_STATE };\nreturn msg;",
