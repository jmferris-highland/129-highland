        "name": "Current Status",
        "func": "const formatStatus = global.get('utils.formatStatus', 'initializers') || (t => t);\n\nconst parts = msg.topic.split('/');\nconst product = parts[4];\nconst status = msg.payload;\n\nconst colorMap = { idle: 'green', running: 'blue', error: 'red' };\nconst fill = colorMap[status] || 'grey';\n\nnode.status({ fill, shape: 'dot', text: formatStatus(`${product.toUpperCase()} (${status.toUpperCase()})`) });\nreturn null;",
