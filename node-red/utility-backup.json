        "g": "ba-g02",
        "name": "Evaluate Result",
        "func": "const formatStatus = global.get('utils.formatStatus', 'initializers');\n\nconst ts = new Date().toISOString();\nconst rc = (msg.rc !== null && typeof msg.rc === 'object') ? msg.rc.code : msg.rc;\n\nif (rc === 0) {\n    msg.payload = {\n        host: \"workflow\",\n        status: \"completed\",\n        timestamp: ts\n    };\n    msg.topic = \"highland/event/backup/completed\";\n\n    node.status({ fill: 'green', shape: 'dot', text: formatStatus('Completed') });\n\n    return [msg, null];\n} else {\n    msg.payload = {\n        host: \"workflow\",\n        status: \"failed\",\n        error: `tar exited with rc ${rc}`,\n        timestamp: ts\n    };\n    msg.topic = \"highland/event/backup/failed\";\n\n    node.status({ fill: 'red', shape: 'dot', text: formatStatus(`Failed (rc ${rc})`) });\n    \n    return [null, msg];\n}",
