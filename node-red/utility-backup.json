        "func": "const host = msg.payload.host || 'unknown';\nconst elapsed = msg.payload.elapsed_hours;\n\nlet message;\nif (host === 'ha') {\n    message = `HA backup stale: last successful was ${elapsed} hours ago`;\n} else {\n    const error = msg.payload.error || 'unknown error';\n    message = `Backup failed: ${host} — ${error}`;\n}\n\nmsg.payload = {\n    targets: [\"people.joseph.ha_companion\"],\n    severity: \"medium\",\n    title: \"Backup Failed\",\n    message\n};\nmsg.topic = \"highland/event/notify\";\nreturn msg;",
