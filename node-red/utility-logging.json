    {
        "id": "55589198f5852320",
        "type": "function",
        "z": "utility-logging",
        "g": "165a0a4b67380d18",
        "name": "Build Notification",
        "func": "const entry = msg.logEntry;\n\n// Pull admin recipients from config — fall back to hardcoded if config unavailable\nconst notifications = global.get('config')?.notifications;\nconst adminOnly = notifications?.defaults?.admin_only || ['joseph'];\n\nconst targets = adminOnly.map(person => `people.${person}.ha_companion`);\n\nmsg.payload = {\n    timestamp: new Date().toISOString(),\n    source: 'logging_utility',\n    targets,\n    severity: 'critical',\n    title: `Critical: ${entry.source}`,\n    message: entry.message,\n    group: 'system_critical',\n    context: entry.context\n};\n\nnode.status({ \n    fill: 'red', \n    shape: 'ring', \n    text: `CRITICAL at ${new Date().toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true })}`\n});\n\nreturn msg;",
