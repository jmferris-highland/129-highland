    {
        "id": "cfg-fn-load",
        "type": "function",
        "z": "utility-config-loader",
        "g": "7f87f76904569482",
        "name": "Parse Configuration",
        "func": "const CONFIG_DIR = '/config';\n\nconst CONFIG_MAP = {\n    device_registry: 'device_registry.json',\n    flow_registry:   'flow_registry.json',\n    location:        'location.json',\n    notifications:   'notifications.json',\n    thresholds:      'thresholds.json',\n    healthchecks:    'healthchecks.json',\n    secrets:         'secrets.json',\n    system:          'system.json'    \n};\n\n// Determine scope: selective or full\nconst prefix = 'highland/command/config/reload/';\nconst topic  = msg.topic || '';\nlet scope = null;\n\nif (topic.startsWith(prefix)) {\n    const name = topic.slice(prefix.length);\n    if (!CONFIG_MAP[name]) {\n        node.warn(`[Config Loader] Unknown config name: ${name}`);\n        return null;\n    }\n    scope = name;\n}\n\nconst toLoad = scope\n    ? { [scope]: CONFIG_MAP[scope] }\n    : CONFIG_MAP;\n\n// Load or initialize global config object\nlet config = global.get('config') || {};\n\nconst loaded = [];\nconst errors = [];\n\nfor (const [key, filename] of Object.entries(toLoad)) {\n    const filepath = path.join(CONFIG_DIR, filename);\n    try {\n        const raw   = fs.readFileSync(filepath, 'utf8');\n        config[key] = JSON.parse(raw);\n        loaded.push(key);\n    } catch (err) {\n        errors.push({ key, filename, error: err.message });\n        node.warn(`[Config Loader] Failed to load ${filename}: ${err.message}`);\n    }\n}\n\nglobal.set('config', config);\n\nmsg.topic   = 'highland/status/config/loaded';\nmsg.payload = {\n    loaded,\n    errors,\n    scope:     scope || 'all',\n    timestamp: new Date().toISOString()\n};\n\nconst formatStatus = global.get('utils.formatStatus', 'initializers');\nconst statusText = errors.length > 0\n    ? formatStatus(`${errors.length} error(s)`)\n    : formatStatus(`${loaded.length} loaded`);\nconst fill = errors.length > 0 ? 'yellow' : 'green';\nnode.status({ fill, shape: 'dot', text: statusText });\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [
            {
                "var": "fs",
                "module": "fs"
            },
            {
                "var": "path",
                "module": "path"
            }
        ],
        "x": 580,
        "y": 80,
        "wires": [
