    {
        "id": "009c88579b168e34",
        "type": "function",
        "z": "utility-weather-radar",
        "g": "47ba118428e5ba52",
        "name": "Format Log Message",
        "func": "const formatStatus = global.get('utils.formatStatus', 'initializers') || (t => t);\n\n// Extract product from topic: highland/event/weather/radar/{product}/rendered|error\nconst parts = msg.topic.split('/');\nconst product = parts[4];\nconst eventType = parts[5]; // \"rendered\" or \"error\"\n\nconst payload = typeof msg.payload === 'string'\n    ? JSON.parse(msg.payload)\n    : msg.payload;\n\nlet level, message, logContext;\n\nif (eventType === 'rendered') {\n    level = 'INFO';\n    message = `Radar loop rendered: ${product}`;\n    logContext = {\n        product,\n        output_path: payload.output_path\n    };\n    node.status({ fill: 'green', shape: 'dot', text: formatStatus(`${product.toUpperCase()} RENDERED`) });\n} else {\n    level = 'ERROR';\n    message = `Radar product failed: ${product}`;\n    logContext = {\n        product,\n        error: payload.error\n    };\n    node.status({ fill: 'red', shape: 'dot', text: formatStatus(`${product.toUpperCase()} ERROR`) });\n}\n\nmsg.payload = {\n    timestamp: new Date().toISOString(),\n    system: 'hub_daemon',\n    source: `weather.radar.${product}`,\n    level,\n    message,\n    context: logContext\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 400,
