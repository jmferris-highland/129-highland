{
  "people": {
    "joseph": {
      "admin": true,
      "channels": {
        "ha_companion": "notify.mobile_app_joseph_phone"
      }
    }
  },
  "areas": {
    "living_room": {
      "channels": {
        "tv": {
            "media_player": "media_player.living_room_television",
            "android_tv": {
                "host": "192.168.1.106",
                "port": 5001,
                "media_player": "media_player.living_room_android_tv"
            },
            "sources": [
                { "name": "FIOS TV", "type": "android_tv" },
                { "name": "Xbox", "type": "webos" }
            ],
            "endpoints": {
                "android_tv": "notify.living_room_stb",
                "webos": "notify.living_room_lg_tv"
            }
        }
      }
    }
  },
  "daily_digest": {
    "enabled": true,
    "recipients": ["joseph","deanna"]
  },
  "defaults": {
    "admin_only": ["joseph"],
    "all": ["joseph"]
  },
  "subscriptions": {
    "dishwasher.cycle_finished": {
      "targets": ["people.joseph.ha_companion", "areas.*.tv"],
      "severity": "low"
    },
    "dishwasher.cycle_finished_reminder": {
      "targets": ["people.joseph.ha_companion", "areas.*.tv"],
      "severity": "low"
    },
    "usps.mail_delivered": {
      "targets": ["people.joseph.ha_companion", "areas.*.tv"],
      "severity": "low"
    },
    "usps.mail_exception": {
        "targets": ["people.joseph.ha_companion", "areas.*.tv"],
        "severity": "medium"
    },
    "weather.alert": {
      "targets": ["people.joseph.ha_companion"],
      "severity": "low"
    },
    "weather.lightning": {
      "targets": ["people.joseph.ha_companion"],
      "severity": "medium"
    },
    "weather.precip_forecast": {
      "targets": ["people.joseph.ha_companion"],
      "severity": "low"
    },
    "email_ingress.imap_failure": {
      "targets": ["people.joseph.ha_companion"],
      "severity": "high"
    }
  }
}
