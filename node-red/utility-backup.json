        "g": "ba-g02",
        "name": "Prepare Command",
        "func": "const ts = flow.get('backup_timestamp');\nconst flowsFile = `/backups/workflow_flows_${ts}.json`;\nconst tarFile = `/backups/workflow_backup_${ts}.tar.gz`;\n\n// exec node: command=\"\" addpay=true — passes msg.payload as the shell command.\n// child_process.exec runs via /bin/sh -c; leading space from concatenation is harmless.\nmsg.payload = `tar -czf ${tarFile} /config /data /assets ${flowsFile}` +\n    ` && rm -f ${flowsFile}` +\n    ` && find /backups -name 'workflow_backup_*.tar.gz' -mtime +7 -delete`;\n\nreturn msg;",
