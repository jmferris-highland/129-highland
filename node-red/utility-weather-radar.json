        "id": "e362462e4761f1c4",
        "type": "function",
        "z": "utility-weather-radar",
        "g": "wr-grp-trigger",
        "name": "Build Configuration",
        "func": "const formatStatus = global.get('utils.formatStatus', 'initializers') || (t => t);\nconst config = global.get('config');\nconst location = config?.location;\nconst secrets = config?.secrets;\nconst weather = config?.weather;\n\nconst payload = {\n    location: {\n        latitude: location.latitude,\n        longitude: location.longitude,\n        timezone: location.timezone ?? 'America/New_York'\n    },\n    stadia: {\n        api_key: secrets.stadia_maps.api_key,\n        style: weather.radar.base_map?.tile_style ?? 'alidade_smooth_dark',\n        zoom: weather.radar.base_map?.zoom ?? 8,\n        grid_size: weather.radar.base_map?.grid_size ?? 5,\n        crop_size: weather.radar.base_map?.crop_size ?? 1280\n    },\n    haos: {\n        host: secrets.home_assistant.host,\n        port: secrets.home_assistant.ssh_port ?? 22,\n        username: secrets.home_assistant.ssh_username,\n        ssh_key_path: secrets.home_assistant.ssh_key_path,\n        www_path: secrets.home_assistant.www_path\n    },\n    mqtt: {\n        host: secrets.mqtt.host ?? 'hub.local',\n        port: secrets.mqtt.port ?? 1883,\n        username: secrets.mqtt.username,\n        password: secrets.mqtt.password,\n        client_id: 'highland-weather-daemon'\n    },\n    radar: {\n        base_map_refresh_days: weather.radar.base_map?.refresh_days ?? 7,\n        products: (weather.radar.loops ?? []).map(loop => ({\n            id: loop.product,\n            enabled: loop.enabled ?? true,\n            cadence_minutes: loop.cadence_minutes ?? 1,\n            frame_count: loop.frame_count,\n            frame_delay_ms: loop.frame_delay_ms,\n            loop_delay_ms: loop.loop_delay_ms,\n            interpolated_frames: loop.interpolated_frames ?? 1,\n            output_filename: `${loop.product}.gif`,\n            color_scheme: loop.color_scheme ?? 2,\n            layers: loop.layers?.filter(l => l.type === 'radar') ?? [{ type: 'radar', opacity: 0.75 }]\n        }))\n    }\n};\n\nmsg.payload = JSON.stringify(payload);\nmsg.retain = true;\nnode.status({ fill: 'green', shape: 'dot', text: formatStatus('RECONFIGURED')});\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
